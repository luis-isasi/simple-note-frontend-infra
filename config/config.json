{
  "region": "us-east-2",
  "domain": {
    "baseDomain": "luis-isasi.com"
  },
  "amplify": {
    "appName": "simple-note-app",
    "repository": "https://github.com/tu-usuario/tu-repositorio",
    "branch": "main",
    "githubTokenSecretName": "github-token"
  },
  "development": {
    "subdomain": "dev-notes",
    "enableAutoBuilds": true
  },
  "testing": {
    "subdomain": "test-notes",
    "enableAutoBuilds": true
  },
  "production": {
    "subdomain": "notes",
    "enableAutoBuilds": true
  }
}